<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="2dp">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:text="@string/ssid_prefix"
        android:singleLine="true"/>
    <EditText
        android:id="@+id/etSSID"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_ssid_pattern"
        android:text="@string/default_ssid"
        android:inputType="text"
        android:autofillHints="none" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:text="@string/psk"
        android:singleLine="true"/>
    <EditText
        android:id="@+id/etPSK"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_psk"
        android:text="@string/default_psk"
        android:inputType="text"
        android:autofillHints="none" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/button_connect"/>
        <Button
            android:id="@+id/btnWifiDevInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wifi_dev_info"/>
        <Button
            android:id="@+id/btnFileHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nand_file_header"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/logTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:typeface="monospace"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"/>
    </ScrollView>

</LinearLayout>
